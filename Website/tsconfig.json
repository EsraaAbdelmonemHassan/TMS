{
  "compilerOptions": {
    "target": "es2015",
    "module": "amd",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "olive": [
        "wwwroot/lib/olive.mvc/dist"
      ],
      "olive/*": [
        "wwwroot/lib/olive.mvc/dist/*"
      ]
    },
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "strict": false,
    "esModuleInterop": true,
    "lib": [
      "es2015",
      "dom"
    ],
    "sourceMap": true,
    "noImplicitAny": false,
    "noEmitOnError": true,
    "removeComments": false
  },
  "compileOnSave": true,
  "exclude": [
    "wwwroot/lib/olive.mvc/src",
    "wwwroot/lib/ansi-styles",
    "wwwroot/lib/find-up",
    "wwwroot/lib/locate-path",
    "wwwroot/lib/p-locate",
    "wwwroot/lib/yargs",
    "obj",
    "bin"
  ],
  "include": [
    "wwwroot/scripts/**/*",
    "wwwroot/lib/**/*"
  ]
}
